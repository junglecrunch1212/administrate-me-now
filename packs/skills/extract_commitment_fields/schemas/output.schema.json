{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "extract_commitment_fields output",
  "type": "object",
  "required": [
    "kind",
    "owed_by_member_id",
    "owed_to_party_id",
    "text_summary",
    "suggested_due",
    "urgency",
    "confidence"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "reply",
        "task",
        "appointment",
        "payment",
        "document_return",
        "visit",
        "other"
      ]
    },
    "owed_by_member_id": {
      "type": "string",
      "minLength": 1
    },
    "owed_to_party_id": {
      "type": "string",
      "minLength": 1
    },
    "text_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "suggested_due": {
      "type": ["string", "null"],
      "description": "ISO-8601 datetime or null."
    },
    "urgency": {
      "type": "string",
      "enum": ["today", "this_week", "this_month", "no_rush"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  }
}
