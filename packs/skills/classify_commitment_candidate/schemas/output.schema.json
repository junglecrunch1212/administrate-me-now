{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "classify_commitment_candidate output",
  "type": "object",
  "required": ["is_candidate", "confidence", "reasons"],
  "additionalProperties": false,
  "properties": {
    "is_candidate": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
