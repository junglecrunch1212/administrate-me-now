{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "classify_message_nature output",
  "type": "object",
  "required": ["classification", "confidence", "reasons"],
  "additionalProperties": false,
  "properties": {
    "classification": {
      "type": "string",
      "enum": ["noise", "transactional", "personal", "professional", "promotional"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
